# Cleerd application environment template.
# Copy to .env.local for local development. Never commit real secret values.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App
# Use the production https:// URL in Vercel before launch.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Must match the Vercel Cron Authorization bearer token. Use a long random value.
CRON_SECRET=replace_with_random_secret

# AI reports
ANTHROPIC_API_KEY=your_anthropic_api_key

# Email
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL=hello@yourdomain.com
REPLY_TO_EMAIL=support@yourdomain.com

# Google Places autocomplete
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Stripe billing
STRIPE_SECRET_KEY=sk_test_or_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_SOLO=price_xxx
STRIPE_PRICE_GROWTH=price_xxx
STRIPE_PRICE_PRO=price_xxx

# Optional local-only destructive reset utility. Never set this in production.
RESET_SUPABASE_CONFIRM=

# Optional growth automation scripts. Keep DRY_RUN=true until campaigns, opt-out language,
# sender domains, and daily limits have been manually verified.
APOLLO_API_KEY=your_apollo_api_key
INSTANTLY_API_KEY=your_instantly_api_key
INSTANTLY_CAMPAIGN_ID=your_instantly_campaign_id
LEADS_PER_RUN=25
DRY_RUN=true
LIVE_OUTREACH_APPROVED=false
