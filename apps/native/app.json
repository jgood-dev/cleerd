{
  "expo": {
    "name": "Cleerd",
    "slug": "cleerd",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "cleerd",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#0f1117"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "io.cleerd.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Cleerd needs camera access to photograph job sites.",
        "NSPhotoLibraryUsageDescription": "Cleerd needs photo library access to attach images to jobs."
      }
    },
    "android": {
      "package": "io.cleerd.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f1117"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Cleerd needs camera access to photograph job sites."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Cleerd needs photo library access to attach images to jobs."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#2563eb"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "FILL_IN_AFTER_EAS_INIT"
      }
    }
  }
}
